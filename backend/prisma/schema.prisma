  ganja_detected         Boolean  @default(false)
  findings_notes         String?
  no_suspicious_activity Boolean  @default(false)
  geo_lat                Decimal? @db.Decimal(10, 7)
  geo_lng                Decimal? @db.Decimal(10, 7)
  photo_url              String?  @db.VarChar(500)
  created_at             DateTime @default(now()) @db.Timestamp(6)

  police_station police_stations @relation(fields: [ps_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  officer        users           @relation("drone_surveillance_officer", fields: [officer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ps_id], map: "idx_ds_ps")
  @@index([officer_id], map: "idx_ds_officer")
  @@index([created_at], map: "idx_ds_date")
}
